{
  "name": "pl_land_registry_monthly",
  "properties": {
    "description": "Monthly incremental load of Land Registry price paid data, then transform to Silver and Gold",
    "activities": [
      {
        "name": "CopyMonthlyCSV",
        "type": "Copy",
        "inputs": [
          {
            "referenceName": "ds_http_land_registry_monthly",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_adls_bronze_land_registry",
            "type": "DatasetReference",
            "parameters": {
              "folder": {
                "value": "@concat('monthly/', formatDateTime(utcnow(), 'yyyy-MM'))",
                "type": "Expression"
              },
              "filename": {
                "value": "@concat('pp-', formatDateTime(utcnow(), 'yyyy-MM'), '.csv')",
                "type": "Expression"
              }
            }
          }
        ],
        "typeProperties": {
          "source": {
            "type": "BinarySource",
            "storeSettings": {
              "type": "HttpReadSettings",
              "requestMethod": "GET"
            }
          },
          "sink": {
            "type": "BinarySink",
            "storeSettings": {
              "type": "AzureBlobFSWriteSettings"
            }
          },
          "enableStaging": false
        }
      },
      {
        "name": "BronzeToSilver",
        "type": "SparkJob",
        "dependsOn": [
          {
            "activity": "CopyMonthlyCSV",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "linkedServiceName": {
          "referenceName": "ls_synapse_dev",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "sparkPool": {
            "referenceName": "sparkpooldev",
            "type": "BigDataPoolReference"
          },
          "rootPath": "config",
          "entryFilePath": "scripts/bronze_to_silver.py",
          "numExecutors": 3,
          "executorSize": "Small",
          "driverSize": "Small"
        }
      },
      {
        "name": "SilverToGold",
        "type": "SparkJob",
        "dependsOn": [
          {
            "activity": "BronzeToSilver",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "linkedServiceName": {
          "referenceName": "ls_synapse_dev",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "sparkPool": {
            "referenceName": "sparkpooldev",
            "type": "BigDataPoolReference"
          },
          "rootPath": "config",
          "entryFilePath": "scripts/silver_to_gold.py",
          "numExecutors": 3,
          "executorSize": "Small",
          "driverSize": "Small"
        }
      }
    ],
    "parameters": {}
  }
}
