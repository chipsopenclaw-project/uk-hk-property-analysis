{
  "name": "pl_land_registry_monthly",
  "properties": {
    "description": "Monthly incremental load of Land Registry price paid data",
    "activities": [
      {
        "name": "CopyMonthlyCSV",
        "type": "Copy",
        "inputs": [
          {
            "referenceName": "ds_http_land_registry_monthly",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_adls_bronze_land_registry",
            "type": "DatasetReference",
            "parameters": {
              "folder": {
                "value": "@concat('monthly/', formatDateTime(utcnow(), 'yyyy-MM'))",
                "type": "Expression"
              },
              "filename": {
                "value": "@concat('pp-', formatDateTime(utcnow(), 'yyyy-MM'), '.csv')",
                "type": "Expression"
              }
            }
          }
        ],
        "typeProperties": {
          "source": {
            "type": "BinarySource",
            "storeSettings": {
              "type": "HttpReadSettings",
              "requestMethod": "GET"
            }
          },
          "sink": {
            "type": "BinarySink",
            "storeSettings": {
              "type": "AzureBlobFSWriteSettings"
            }
          },
          "enableStaging": false
        }
      }
    ],
    "parameters": {}
  }
}
