{
  "name": "pl_land_registry_monthly",
  "properties": {
    "description": "Monthly incremental load of Land Registry price paid data, then transform to Silver and Gold",
    "activities": [
      {
        "name": "CopyMonthlyCSV",
        "type": "Copy",
        "inputs": [
          {
            "referenceName": "ds_http_land_registry_monthly",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_adls_bronze_land_registry",
            "type": "DatasetReference",
            "parameters": {
              "folder": {
                "value": "@concat('monthly/', formatDateTime(utcnow(), 'yyyy-MM'))",
                "type": "Expression"
              },
              "filename": {
                "value": "@concat('pp-', formatDateTime(utcnow(), 'yyyy-MM'), '.csv')",
                "type": "Expression"
              }
            }
          }
        ],
        "typeProperties": {
          "source": {
            "type": "BinarySource",
            "storeSettings": {
              "type": "HttpReadSettings",
              "requestMethod": "GET"
            }
          },
          "sink": {
            "type": "BinarySink",
            "storeSettings": {
              "type": "AzureBlobFSWriteSettings"
            }
          },
          "enableStaging": false
        }
      },
      {
        "name": "BronzeToSilver",
        "type": "WebActivity",
        "dependsOn": [
          {
            "activity": "CopyMonthlyCSV",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "url": "https://syn-ukhkprop-dev.dev.azuresynapse.net/livyApi/versions/2019-11-01-preview/sparkPools/sparkpooldev/batches",
          "method": "POST",
          "authentication": {
            "type": "MSI",
            "resource": "https://dev.azuresynapse.net"
          },
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "file": "abfss://config@stukhkpropdev.dfs.core.windows.net/scripts/bronze_to_silver.py",
            "name": "bronze_to_silver",
            "executorMemory": "4g",
            "executorCores": 4,
            "numExecutors": 3,
            "driverMemory": "4g",
            "driverCores": 4
          }
        }
      },
      {
        "name": "WaitForBronzeToSilver",
        "type": "Wait",
        "dependsOn": [
          {
            "activity": "BronzeToSilver",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "waitTimeInSeconds": 1800
        }
      },
      {
        "name": "SilverToGold",
        "type": "WebActivity",
        "dependsOn": [
          {
            "activity": "WaitForBronzeToSilver",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "url": "https://syn-ukhkprop-dev.dev.azuresynapse.net/livyApi/versions/2019-11-01-preview/sparkPools/sparkpooldev/batches",
          "method": "POST",
          "authentication": {
            "type": "MSI",
            "resource": "https://dev.azuresynapse.net"
          },
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "file": "abfss://config@stukhkpropdev.dfs.core.windows.net/scripts/silver_to_gold.py",
            "name": "silver_to_gold",
            "executorMemory": "4g",
            "executorCores": 4,
            "numExecutors": 3,
            "driverMemory": "4g",
            "driverCores": 4
          }
        }
      }
    ],
    "parameters": {}
  }
}
